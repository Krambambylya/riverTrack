{
  "name": "rivertrack",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "prebuild:apk": "npx expo prebuild --platform android",
    "build:apk": "npx eas build --platform android --profile preview --local --output ./build/rivertrack.apk",
    "build:apk:production": "npx eas build --platform android --profile production --local --output ./build/rivertrack.apk",
    "build:aab:production": "npx eas build --platform android --profile production-aab --local --output ./build/rivertrack.aab"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@maplibre/maplibre-react-native": "^10.4.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/native": "^7.1.33",
    "@turf/along": "^7.3.4",
    "@turf/helpers": "^7.3.4",
    "@turf/length": "^7.3.4",
    "@turf/nearest-point-on-line": "^7.3.4",
    "expo": "~55.0.12",
    "expo-constants": "~55.0.12",
    "expo-dev-client": "~55.0.23",
    "expo-font": "~55.0.6",
    "expo-image": "~55.0.8",
    "expo-linking": "~55.0.11",
    "expo-location": "~55.1.7",
    "expo-maps": "~55.0.15",
    "expo-router": "~55.0.11",
    "expo-splash-screen": "~55.0.16",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-web-browser": "~55.0.13",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
